modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "python312Packages.pytest_7", "sqlite"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run uvicorn app:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[[workflows.workflow]]
name = "Tests"
mode = "sequential"
author = 17731565

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv sync"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run pytest -v --disable-warnings"

[[workflows.workflow]]
name = "API Server"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run uvicorn app:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "app:app"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
