modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["python312Packages.pytest_7", "sqlite"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Tests"
mode = "sequential"
author = 17731565

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pytest -v --disable-warnings"

[[workflows.workflow]]
name = "API Server"
mode = "sequential"
author = 17731565

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn app:app --reload"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "app:app"]
